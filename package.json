{
  "name": "tele-agent-k",
  "version": "1.0.0",
  "description": "Telegram bot that interfaces with Claude Code CLI",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test tests/*.test.js",
    "test:e2e": "npx playwright test tests/e2e-webhook.spec.js",
    "test:all": "node --test tests/*.test.js && npx playwright test tests/e2e-webhook.spec.js",
    "test:report": "node tests/generate-report.js"
  },
  "dependencies": {
    "@playwright/test": "^1.58.2",
    "better-sqlite3": "^11.0.0",
    "cheerio": "^1.2.0",
    "docx": "^9.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "node-fetch": "^2.7.0",
    "playwright": "^1.58.1",
    "telegraf": "^4.16.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "lunar-javascript": "^1.7.7"
  }
}
